# ⚠️ We have migrated from Lemon Squeezy to Gumroad.
# The following Lemon Squeezy environment variables are no longer needed
# for checkout — purchase buttons now link directly to Gumroad product pages.
#
# LEMONSQUEEZY_API_KEY=deprecated
# LEMONSQUEEZY_STORE_ID=deprecated
# LEMONSQUEEZY_WEBHOOK_SECRET=deprecated
#
# The webhook handler at /api/webhook/lemonsqueezy is kept for legacy
# order tracking. If you want to keep it functional, uncomment and set:
# LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# ℹ️ Site URL (used for generating canonical URLs, metadata, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
